# ==========================================
# FLASK API ENVIRONMENT VARIABLES TEMPLATE
# ==========================================
# Instructions: Copy the contents of this file, paste them into a new file 
# named '.env', and replace the placeholder values with your actual secrets.

# 1. Flask Core Settings
FLASK_APP=run.py
FLASK_ENV=dev
FLASK_DEBUG=1

# 2. Security Keys
# WARNING: In production, change these to long, random cryptographic strings!
# Generate one in your terminal using: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-flask-key-here
JWT_SECRET_KEY=your-super-secret-jwt-key-here

# 3. Database Configuration
# By default, the app uses a local SQLite database. 
# Only uncomment and change these if you are using an external database (like PostgreSQL).
# DEV_DATABASE_URL=sqlite:///api-dev.sqlite
# DATABASE_URL=postgresql://db_user:db_password@localhost:5432/my_production_db